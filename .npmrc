# pnpm dedup config. Without this, multiple peer-dep permutations of
# `@iblai/*` end up in `node_modules/.pnpm/` (e.g. one copy paired with
# `@iblai/data-layer@1.5.7` and another with `1.5.11`). React contexts
# created by the SDK (TenantContext, ReactReduxContext, etc.) live on
# the module instance, so consumers in one copy can't see providers
# from another -- `useTenantContext()` returns `undefined`.
#
# `dedupe-peer-dependents=true` is the pnpm 9+ setting that tells pnpm
# to collapse identical-by-content packages even when their peer-dep
# chains differ; `public-hoist-pattern` lifts the @iblai namespace to
# the root `node_modules/` so the bundler always finds the same copy.
dedupe-peer-dependents=true
public-hoist-pattern[]=@iblai/*

# Block recently-published versions from third-party deps (supply-chain
# guardrail). 10080 minutes = 7 days. `@iblai/*` is exempt -- we ship
# SDK fixes and the host repos consume them within hours.
min-release-age=7
minimum-release-age=10080
minimum-release-age-exclude[]=@iblai/*

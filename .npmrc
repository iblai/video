# Block recently-published versions from third-party deps (supply-chain
# guardrail). 10080 minutes = 7 days. `@iblai/*` is exempt -- we ship
# SDK fixes and the host repos consume them within hours.
min-release-age=7
minimum-release-age=10080
minimum-release-age-exclude[]=@iblai/iblai-js
minimum-release-age-exclude[]=@iblai/web-containers
minimum-release-age-exclude[]=@iblai/web-utils
minimum-release-age-exclude[]=@iblai/data-layer
minimum-release-age-exclude[]=@iblai/agent-ai
minimum-release-age-exclude[]=@iblai/iblai-api
minimum-release-age-exclude[]=@iblai/iblai-web-mentor
minimum-release-age-exclude[]=@iblai/mcp

enable-pre-post-scripts = true
min-release-age=7
minimum-release-age=10080
# Skip the maturity guard for packages we're pulling in to patch open
# Dependabot alerts — waiting 7 days on a fresh CVE fix is worse than
# the theoretical supply-chain risk of installing a recent patch.
# minimum-release-age-exclude[]=next
# minimum-release-age-exclude[]=@next/*
# minimum-release-age-exclude[]=axios
# minimum-release-age-exclude[]=hono
# minimum-release-age-exclude[]=dompurify
# minimum-release-age-exclude[]=vite
# minimum-release-age-exclude[]=lodash
# minimum-release-age-exclude[]=fast-uri
# minimum-release-age-exclude[]=ip-address
# minimum-release-age-exclude[]=postcss
# minimum-release-age-exclude[]=follow-redirects
# minimum-release-age-exclude[]=@hono/node-server
# minimum-release-age-exclude[]=picomatch
# minimum-release-age-exclude[]=minimatch
# minimum-release-age-exclude[]=prismjs
save-exact=true

